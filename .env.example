# Supabase (Server-only: use service role key only on server)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Brevo (E-Mail – funktioniert mit Gmail ohne eigene Domain)
# API-Key: https://app.brevo.com/settings/keys/api
BREVO_API_KEY=your-brevo-api-key
FROM_EMAIL=Push <noreplyandinfo.push@gmail.com>

# App URL (für DOI- und Referral-Links)
NEXT_PUBLIC_BASE_URL=https://push-waitlist.vercel.app

# Optional: Consent-Hash-Salt (Standard wird genutzt, wenn nicht gesetzt)
CONSENT_HASH_SALT=your-random-salt

# Admin (Basic Auth für /admin)
ADMIN_USER=admin
ADMIN_PASSWORD=changeme

# Optional: Analytics (z. B. Plausible)
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=push.yourdomain.com
