# Supabase (Server-only: use service role key only on server)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend (E-Mail)
RESEND_API_KEY=re_xxxx
FROM_EMAIL=Push <noreply@yourdomain.com>

# App URL (for DOI and referral links)
NEXT_PUBLIC_BASE_URL=https://push.yourdomain.com

# Optional: Consent hash salt (default used if not set)
CONSENT_HASH_SALT=your-random-salt

# Admin (Basic Auth for /admin)
ADMIN_USER=admin
ADMIN_PASSWORD=changeme

# Optional: Analytics (e.g. Plausible)
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=push.yourdomain.com
